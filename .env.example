# =============================================================================
# QuantEngine Pro - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your API keys:
#   cp .env.example .env
# =============================================================================

# ---- Required: LLM Provider ----
# DeepSeek (free tier available): https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# ---- Optional: Alternative LLM Providers ----
# OPENAI_API_KEY=sk-your-openai-api-key
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# ---- Optional: Redis (production only) ----
# Redis is auto-configured when using docker-compose.
# For local dev, Redis is optional — system falls back to memory cache.
# REDIS_HOST=localhost
# REDIS_PORT=6379

# ---- Optional: Notification Webhooks ----
# DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=xxx
# WECHAT_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx
